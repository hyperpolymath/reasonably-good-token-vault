# Mustfile — declarative state contract for RGTV

version: 1

metadata:
  name: rgtv-state-contract
  spec: v0.1.0
  description: "Invariant checks for RGTV vault-broker, vault-worker, and rgtv CLI."

checks:
  - name: vault-worker-wrangler-ids-set
    description: "wrangler.toml must not contain placeholder KV namespace IDs."
    run: "bash -uc '! grep -q REPLACE_WITH vault-worker/wrangler.toml'"

  - name: no-secrets-in-wrangler
    description: "wrangler.toml must not contain RGTV_AGENT_TOKEN value (secrets go via wrangler secret put)."
    run: "bash -uc '! grep -qE \"RGTV_AGENT_TOKEN\\s*=\\s*\\\"[^\\\"]+\\\"\" vault-worker/wrangler.toml'"

  - name: no-banned-languages
    description: "No V-lang, TypeScript, or Go source files."
    run: "bash -uc '! find . -name \"*.v\" -not -path \"*/target/*\" | grep -qv v.mod || true; ! find . -name \"*.ts\" -not -path \"*/target/*\" -not -path \"*/.git/*\" | grep -q . '"

  - name: spdx-headers-present
    description: "All Rust source files must have SPDX-License-Identifier header."
    run: "bash -uc 'for f in $(find . -name \"*.rs\" -not -path \"*/target/*\" -not -path \"*/.git/*\"); do grep -qL \"SPDX-License-Identifier\" \"$f\" && echo \"Missing SPDX: $f\" && exit 1; done; true'"

  - name: gitignore-has-worker-build
    description: ".gitignore must exclude vault-worker build artefacts."
    run: "bash -uc 'grep -q \"vault-worker/build\" .gitignore'"
