# Dustfile — recovery and rollback semantics for RGTV

version: 1

recovery:
  worker-deploy:
    - name: wrangler-rollback
      notes: "CF Workers keeps the previous deployment. Roll back via Cloudflare dashboard → Workers → rgtv-vault → Deployments → Rollback."

  credentials-kv:
    - name: restore-credential
      notes: "If a credential value is corrupted or deleted, re-add it: just worker-cred-put HINT value"

  agent-token:
    - name: rotate-token
      notes: "If RGTV_AGENT_TOKEN is compromised: wrangler secret put RGTV_AGENT_TOKEN (new value), then update all consumers."

  fly-broker:
    - name: redeploy-broker
      notes: "If rgtv-nesy is degraded: NESY_INGEST_TOKEN=<tok> ./deploy-fly.sh rgtv"
      rollback: "fly releases -a rgtv-nesy && fly deploy --image <previous-image>"
