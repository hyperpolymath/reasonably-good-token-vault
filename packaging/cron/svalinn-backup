#!/bin/bash
# SPDX-License-Identifier: PMPL-1.0-or-later
# Svalinn Vault - Cron Backup Fallback
#
# This script provides a fallback backup mechanism if systemd fails
# It should only run if the systemd timer hasn't executed successfully

# Configuration
BACKUP_DIR="/var/lib/svalinn/backups"
LOG_FILE="/var/log/svalinn/backup-cron.log"
LOCK_FILE="/tmp/svalinn-backup-cron.lock"

# Check if systemd timer ran successfully today
if systemctl is-active svalinn-backup.timer >/dev/null 2>&1; then
    # Check last backup time
    LAST_BACKUP=$(find "$BACKUP_DIR" -name "*.age" -type f -newermt "today 00:00" | head -1)
    if [ -n "$LAST_BACKUP" ]; then
        echo "$(date -Is) - Systemd backup already ran, skipping cron fallback" >> "$LOG_FILE"
        exit 0
    fi
fi

# Acquire lock to prevent concurrent execution
if ! (set -o noclobber; echo "$$" > "$LOCK_FILE") 2> /dev/null; then
    echo "$(date -Is) - Backup already in progress, exiting" >> "$LOG_FILE"
    exit 1
fi

# Trap to release lock on exit
trap 'rm -f "$LOCK_FILE"' EXIT

# Run backup
echo "$(date -Is) - Starting cron fallback backup" >> "$LOG_FILE"

if /usr/bin/svalinn backup create --output "$BACKUP_DIR"; then
    echo "$(date -Is) - Backup completed successfully" >> "$LOG_FILE"
    exit 0
else
    echo "$(date -Is) - Backup failed with error: $?" >> "$LOG_FILE"
    exit 1
fi
